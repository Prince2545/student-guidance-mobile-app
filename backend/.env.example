# Copy to `.env`. Never commit `.env`.
# No spaces around =. No quotes unless the key itself contains special chars.
NVIDIA_API_KEY=
# Optional fallback name:
# API_KEY=

# Optional model id (must be enabled for your NVIDIA account)
AI_MODEL=meta/llama-3.1-8b-instruct

# Set to 1 to run one NVIDIA ping on server start (uses quota)
# MENTOR_SELF_TEST=1

# Optional LAN gate: if set, clients must send header x-app-key: <same value>
# (Leave unset so the Expo app works without changes.)
# MENTOR_APP_KEY=

# Optional body limits (defaults shown)
# MENTOR_MAX_MESSAGE_LENGTH=8000
# MENTOR_MAX_CONTEXT_HINT_LENGTH=4000
