# Copy to `.env` in this folder. Never commit `.env`.

# Mentor API base URL (no trailing slash). Default in app.config is the Render deploy below.
# For LAN dev (phone → PC): EXPO_PUBLIC_MENTOR_BACKEND_URL=http://<PC_LAN_IP>:5000
EXPO_PUBLIC_MENTOR_BACKEND_URL=https://student-guidance-mobile-app.onrender.com
MENTOR_BACKEND_URL=

# Required when backend sets MENTOR_APP_KEY — must match exactly (this is NOT the NVIDIA key).
EXPO_PUBLIC_MENTOR_APP_KEY=
