# Copy to `.env` in this folder. Never commit `.env`.

# Mentor API base URL (no trailing slash). Prefer HTTPS in production (e.g. Render).
# EXPO_PUBLIC_MENTOR_BACKEND_URL=https://your-service.onrender.com
# LAN dev fallback in app.config if unset: http://192.168.31.161:5000
EXPO_PUBLIC_MENTOR_BACKEND_URL=
MENTOR_BACKEND_URL=

# Required for mentor gate — must exactly match backend MENTOR_APP_KEY
EXPO_PUBLIC_MENTOR_APP_KEY=
